{
  "name": "stream-channeler-tuner",
  "description": "Companion for Stream Channeler that controls media playback and assists in channel creation.",
  "version": "0.0.1",
  "author": {
    "name": "ryn.cx"
  },
  "scripts": {
    "format": "prettier -w ./",
    "analize": "cross-env npm_config_report=true npm run build",
    "build": "webpack --config config/webpack.config.prod.cjs",
    "dev": "webpack --config config/webpack.config.dev.cjs",
    "prepare": "husky install",
    "lint-staged": "lint-staged"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ryn-cx/stream-channeler-tuner"
  },
  "private": true,
  "dependencies": {
    "@trim21/gm-fetch": "^0.3.0",
    "jquery": "^4.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --ignore-path ./.prettierignore --write "
    ]
  },
  "devDependencies": {
    "@types/greasemonkey": "^4.0.7",
    "@types/jquery": "^4.0.0",
    "@types/node": "^22.17.0",
    "@types/webpack-env": "^1.18.8",
    "browserslist": "^4.28.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "userscript-metadata-webpack-plugin": "^0.4.2",
    "webpack": "^5.105.4",
    "webpack-bundle-analyzer": "^5.2.0",
    "webpack-cli": "^7.0.2",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-merge": "^6.0.1",
    "webpack-sources": "^3.3.4"
  }
}
